# fairy-tales-deepseek-openai provider config (OpenAI-compatible endpoint)
# Point this at your gateway's /v1 base.
PI_BASE_URL=http://localhost:8000/v1
PI_API_KEY=sk-your-key-here
PI_MODEL=deepseek-v4-pro

# Where session records are persisted (default: ./.pi/sessions)
# PI_SESSION_DIR=~/.pi/sessions
